{
  "name": "pi-scraper",
  "version": "0.1.4",
  "description": "Crawl, map, and structured extraction for Pi — scraper-first, Pi-native, and local-first.",
  "keywords": [
    "pi-package",
    "pi",
    "scraping",
    "crawler",
    "web-scraping",
    "structured-extraction",
    "firecrawl"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonkramer/pi-scraper"
  },
  "bugs": {
    "url": "https://github.com/brandonkramer/pi-scraper/issues"
  },
  "homepage": "https://github.com/brandonkramer/pi-scraper#readme",
  "type": "module",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/__tests__/**",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '.pi/**' --exclude '**/.pi/**'",
    "test:tools": "vitest run src/tools/__tests__/tools-smoke.test.ts --reporter=verbose --exclude '.pi/**' --exclude '**/.pi/**'",
    "smoke:install": "node bench/scripts/install-smoke.mjs",
    "smoke:live": "vitest run src/tools/__tests__/tools-smoke.live.test.ts --reporter=verbose",
    "smoke:browser": "vitest run src/browser/__tests__/browser-smoke.test.ts --reporter=verbose",
    "audit:strict": "npm audit --omit=dev --audit-level=high",
    "lint:workflows": "github-actionlint .github/workflows/*.yml",
    "bench": "node bench/bench.mjs eval/corpus.json",
    "compare:extract": "node bench/extract/compare-extractors.mjs",
    "compare:serialize": "node bench/serialize/compare-serializers.mjs",
    "profile:linkedom": "node bench/parse/profile-linkedom-parse.mjs",
    "profile:markdown": "node bench/serialize/profile-turndown-rules.mjs",
    "bench:tool-registration": "node bench/tools/registration.mjs",
    "compare:dom": "node bench/dom/compare-adapters.mjs",
    "compare:dom:memory": "node --expose-gc bench/dom/memory-adapters.mjs",
    "compare:dom:diff": "node bench/dom/diff-stability.mjs",
    "compare:dom:batch": "node bench/dom/batch-timing.mjs",
    "capture:dom:real": "node bench/dom/capture-real-world.mjs",
    "spike:cheerio": "node bench/dom/prototype-adapters.mjs",
    "prepublishOnly": "npm run typecheck"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "latest",
    "@sinclair/typebox": "latest",
    "@types/node": "latest",
    "@types/turndown": "^5.0.6",
    "css-select": "^6.0.0",
    "defuddle": "^0.18.1",
    "dom-serializer": "^2.0.0",
    "domhandler": "^5.0.3",
    "domutils": "^3.2.2",
    "github-actionlint": "^1.7.12",
    "html-to-text": "^10.0.0",
    "htmlparser2": "^12.0.0",
    "node-html-markdown": "^2.0.0",
    "typescript": "latest",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.19.0",
    "pi": ">=0.65.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "linkedom": "^0.18.12",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^8.2.0"
  },
  "optionalDependencies": {
    "pdfjs-dist": "^5.7.284",
    "playwright": "^1.59.1"
  }
}
